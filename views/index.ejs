<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KelselPDF - Master Your Exams with AI</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <style>
        /* Landing Page specific styles */
        body {
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        
        .hero {
            padding: 8rem 2rem 4rem;
            text-align: center;
            max-width: 1000px;
            margin: 0 auto;
            flex: 1;
        }
        
        .hero h1 {
            font-size: clamp(3rem, 5vw, 5rem);
            line-height: 1.1;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, var(--cta-color), var(--success));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: fadeInDown 0.8s ease-out;
        }
        
        .hero p {
            font-size: clamp(1.1rem, 2vw, 1.3rem);
            color: var(--ntxt-color);
            margin-bottom: 2.5rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }
        
        .hero-btns {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            animation: fadeInUp 0.8s ease-out 0.4s both;
            flex-wrap: wrap;
        }
        
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            max-width: 1200px;
            margin: 4rem auto;
            padding: 0 2rem;
        }
        
        .feature-card {
            padding: 2.5rem 2rem;
            text-align: center;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s;
            border: 1px solid var(--cbg-color-2);
        }
        
        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            border-color: var(--cta-color);
        }
        
        .feature-icon {
            font-size: 3.5rem;
            margin-bottom: 1.5rem;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
        }
        
        /* Animations */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background: var(--neu-color);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 10px var(--shd-color);
        }
        
        .nav-links {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .hero {
                padding: 4rem 1rem 2rem;
            }
            .hero h1 {
                font-size: 2.2rem;
                line-height: 1.2;
            }
            .hero p {
                font-size: 1rem;
            }
            .hero-btns {
                flex-direction: column;
                width: 100%;
                gap: 1rem;
            }
            .hero-btns .btn, .hero-btns .btn-ai {
                width: 100%;
                padding: 15px 20px !important;
                font-size: 1rem !important;
                box-sizing: border-box;
            }
            .features {
                grid-template-columns: 1fr;
                padding: 0 1rem;
                margin: 2rem auto;
            }
            nav {
                flex-direction: row; /* Keep logo and hamburger on same line */
                justify-content: space-between;
                align-items: center;
                padding: 1rem;
            }
            .mobile-landing-toggle {
                display: block;
                background: transparent;
                border: none;
                color: var(--ntxt-color);
                cursor: pointer;
            }
            .nav-links {
                display: none; /* Hidden by default on mobile */
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 100%;
                left: 0;
                background: var(--neu-color);
                padding: 1rem;
                box-shadow: 0 4px 6px var(--shd-color);
                border-top: 1px solid var(--cbg-color-2);
            }
            .nav-links.open {
                display: flex;
            }
            .feature-card {
                padding: 1.5rem 1rem;
            }
        }
    </style>
</head>
<body>
    <nav style="position: sticky; top: 0; z-index: 1000; display: flex; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 1200px; margin: 0 auto;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <img id="navLogo" src="/acct/img/KelselPDF.png" alt="Logo" style="height: 40px; transition: 0.3s;">
            </div>
            
            <button class="mobile-landing-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')" style="display: none;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>

            <div class="nav-links">
                <% if(locals.user_id) { %>
                    <a href="/dashboard" class="btn btn-ai" style="padding: 10px 20px;">Dashboard</a>
                <% } else { %>
                    <a href="/login" style="color: var(--text-color); text-decoration: none; font-weight: 500;">Login</a>
                    <a href="/register" class="btn btn-ai" style="padding: 10px 20px;">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>

    <section class="hero">
        <h1>Master Your Exams with AI Intelligence</h1>
        <p>The ultimate platform for modern students. Practice with real exam questions, track your progress with deep analytics, and let our sophisticated AI tutor guide you to perfect scores.</p>
        <div class="hero-btns">
            <% if(locals.user_id) { %>
                <a href="/dashboard" class="btn btn-ai" style="font-size: 1.2rem; padding: 15px 40px; border-radius: 30px;">Go to Dashboard</a>
            <% } else { %>
                <a href="/register" class="btn btn-ai" style="font-size: 1.2rem; padding: 15px 40px; border-radius: 30px;">Start Learning Free</a>
                <a href="/login" class="btn" style="font-size: 1.2rem; padding: 15px 40px; border-radius: 30px;">Access Account</a>
            <% } %>
        </div>
    </section>

    <section class="features">
        <div class="glass-panel feature-card">
            <div class="feature-icon"><img src="/acct/img/Gemini_Generated_Image_xt0afhxt0afhxt0a.png" alt="Mock Exams" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; box-shadow: 0 4px 10px rgba(0,0,0,0.2);"></div>
            <h3>Mock Exams</h3>
            <p style="color: var(--ntxt-color); margin-top: 10px; line-height: 1.5;">Experience real exam conditions with strict countdown timers, secure testing environments, and instant grading engines.</p>
        </div>
        <div class="glass-panel feature-card">
            <div class="feature-icon"><img src="/acct/img/Gemini_Generated_Image_cx6v74cx6v74cx6v-removebg-preview.png" alt="AI Tutor" style="width: 100px; height: 100px; object-fit: contain;"></div>
            <h3>AI Tutor</h3>
            <p style="color: var(--ntxt-color); margin-top: 10px; line-height: 1.5;">Generate infinite custom practice questions and receive intelligent feedback on your theory answers instantly.</p>
        </div>
        <div class="glass-panel feature-card">
            <div class="feature-icon"><img src="/acct/img/Gemini_Generated_Image_jwul3ijwul3ijwul-removebg-preview.png" alt="Deep Analytics" style="width: 100px; height: 100px; object-fit: contain;"></div>
            <h3>Deep Analytics</h3>
            <p style="color: var(--ntxt-color); margin-top: 10px; line-height: 1.5;">Track your pass rates, exam completion times, and total course mastery through beautiful visual charts.</p>
        </div>
    </section>

    <footer style="text-align: center; padding: 3rem 2rem; border-top: 1px solid var(--cbg-color-2); margin-top: auto;">
        <div style="display: flex; justify-content: center; gap: 15px; margin-bottom: 1rem;">
            <a href="#" style="color: var(--ntxt-color); text-decoration: none;">Privacy Policy</a>
            <span style="color: var(--cbg-color-2);">|</span>
            <a href="#" style="color: var(--ntxt-color); text-decoration: none;">Terms of Service</a>
        </div>
        <p style="color: var(--ntxt-color); font-weight: 500;">&copy; 2026 KelselPDF. Built for student success.</p>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const logo = document.getElementById('navLogo');
            
            // Watch for theme changes applied by theme.js
            const observer = new MutationObserver((mutations) => {
                mutations.forEach((mutation) => {
                    if (mutation.attributeName === 'data-theme') {
                        if (document.documentElement.getAttribute('data-theme') === 'dark') {
                            logo.src = '/acct/img/KelselPDF 2.png';
                        } else {
                            logo.src = '/acct/img/KelselPDF.png';
                        }
                    }
                });
            });
            
            observer.observe(document.documentElement, { attributes: true });
            
            // Initial check
            if (document.documentElement.getAttribute('data-theme') === 'dark') {
                logo.src = '/acct/img/KelselPDF 2.png';
            }
        });
    </script>
</body>
</html>
