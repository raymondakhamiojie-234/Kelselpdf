<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Certificate Verification - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: var(--bg-color);
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
        }
        .verify-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 3rem;
            max-width: 600px;
            width: 100%;
            text-align: center;
            box-shadow: var(--hover-shadow);
        }
        .status-icon {
            font-size: 5rem;
            margin-bottom: 1rem;
        }
        .status-valid { color: #28a745; }
        .status-invalid { color: #dc3545; }
        .cert-detail {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            padding: 1.5rem;
            border-radius: 8px;
            margin-top: 2rem;
            text-align: left;
        }
        .detail-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px dashed var(--border-color);
        }
        .detail-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .detail-label {
            color: #777;
            font-weight: 500;
        }
        .detail-value {
            font-weight: 600;
            color: var(--text-color);
        }
    </style>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
<link rel="icon" type="image/png" href="/acct/img/KelselPDF.png">
</head>
<body>
    <div class="verify-card">
        <img src="/acct/img/KelselPDF.png" alt="KelselPDF" style="max-width: 150px; margin-bottom: 2rem;">
        
        <% if (valid) { %>
            <div class="status-icon status-valid">✓</div>
            <h1 style="color: var(--text-color);">Valid Certificate</h1>
            <p style="color: #777;">This certificate is officially recognized by KelselPDF Skills Academy.</p>
            
            <div class="cert-detail">
                <div class="detail-row">
                    <span class="detail-label">Recipient Name:</span>
                    <span class="detail-value"><%= certificate.user_name %></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Course Completed:</span>
                    <span class="detail-value"><%= certificate.course_title %></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Date Issued:</span>
                    <span class="detail-value"><%= new Date(certificate.issued_at).toLocaleDateString() %></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Certificate ID:</span>
                    <span class="detail-value" style="font-family: monospace;"><%= certificate.unique_hash %></span>
                </div>
            </div>
        <% } else { %>
            <div class="status-icon status-invalid">✗</div>
            <h1 style="color: var(--text-color);">Invalid Certificate</h1>
            <p style="color: #777;">We could not find a record of this certificate in our system. It may have been revoked or the ID is incorrect.</p>
        <% } %>
        
        <div style="margin-top: 3rem;">
            <a href="/" class="btn btn-secondary">Go to Homepage</a>
        </div>
    </div>
</body>
</html>


