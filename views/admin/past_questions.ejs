<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Past Questions - Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <style>
        .drag-drop-zone {
            border: 2px dashed var(--cbg-color-2);
            border-radius: 8px;
            padding: 2rem;
            text-align: center;
            background: var(--cbg-color);
            transition: all 0.3s ease;
            cursor: pointer;
            margin-bottom: 1rem;
            position: relative;
        }
        .drag-drop-zone.dragover {
            border-color: var(--cta-color);
            background: rgba(43, 91, 228, 0.1);
        }
        .drag-drop-zone input[type="file"] {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            opacity: 0;
            cursor: pointer;
        }
        .file-info {
            margin-top: 10px;
            font-weight: bold;
            color: var(--cta-color);
        }
        .divider {
            text-align: center;
            margin: 1rem 0;
            position: relative;
            color: var(--ntxt-color);
        }
        .divider::before, .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 40%;
            height: 1px;
            background: var(--cbg-color-2);
        }
        .divider::before { left: 0; }
        .divider::after { right: 0; }
    </style>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
</head>
<body class="dashboard-body">
    <nav class="sidebar">
        <img src="/acct/img/KelselPDF.png" alt="KelselPDF Logo" class="brand-logo" style="max-width: 150px; margin: 0 auto 2rem; display: block;">
        <ul>
            <li><a href="/admin">📊 Overview</a></li>
            <li><a href="/admin/users">👥 Users</a></li>
            <li><a href="/admin/payments">💰 Payments</a></li>
            <li><a href="/admin/subscriptions">📅 Subscriptions</a></li>
            <li><a href="/admin/questions">📝 Upload Questions</a></li>
            <li><a href="/admin/past_questions" class="active">📁 Past Questions</a></li>
            <li style="margin-top: 2rem;"><a href="/dashboard">← Back to App</a></li>
        </ul>
    </nav>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('../acct/partials/app_header', { page_title: 'Past Questions', page_desc: 'Upload question banks' }) %>

        <h2>Add Past Question Material</h2>
        
        <div class="glass-panel" style="max-width: 650px;">
            <% if (success) { %> <div class='alert alert-success'><%= success %></div> <% } %>
            <% if (error) { %> <div class='alert alert-error'><%= error %></div> <% } %>
            
            <form method="POST" action="/admin/past_questions" enctype="multipart/form-data">
                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 2;">
                        <label>Course</label>
                        <input type="text" name="course_code" placeholder="e.g. MTH101" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Year</label>
                        <input type="text" name="year" placeholder="e.g. 2023" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Exam Type</label>
                        <select name="type" required>
                            <option value="Midterm">Midterm</option>
                            <option value="Final">Final</option>
                            <option value="Mock">Mock</option>
                        </select>
                    </div>
                </div>

                <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label>Department (for new courses)</label>
                        <select name="department_id" required>
                            <option value="1">Computer Science</option>
                            <option value="2">Electrical Engineering</option>
                            <option value="3">Business Administration</option>
                            <option value="gst">General Studies (All Depts)</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Level (for new courses)</label>
                        <select name="level" required>
                            <option value="100">100 Level</option>
                            <option value="200">200 Level</option>
                            <option value="300">300 Level</option>
                            <option value="400">400 Level</option>
                            <option value="500">500 Level</option>
                        </select>
                    </div>
                </div>

                <div class="drag-drop-zone" id="dropZone" style="margin-top: 1.5rem;">
                    <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">📥</div>
                    <h3>Drag & Drop your file here</h3>
                    <p style="color: var(--ntxt-color); margin-top: 5px;">or click to browse your computer (PDFs recommended)</p>
                    <input type="file" name="pq_file" id="fileInput" accept=".pdf,.docx,.txt">
                    <div class="file-info" id="fileInfo"></div>
                </div>

                <div class="divider">OR</div>

                <div class="form-group">
                    <label>Provide External URL Link instead</label>
                    <input type="url" name="file_link" placeholder="https://..." id="urlInput">
                </div>

                <button type="submit" class="btn btn-ai" style="width: 100%; margin-top: 1rem; padding: 15px; font-size: 1.1rem;">Save Past Question</button>
            </form>
        </div>
    </main>

    <script>
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('fileInfo');
        const urlInput = document.getElementById('urlInput');

        // Highlight drop zone when dragging
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropZone.classList.add('dragover');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropZone.classList.remove('dragover');
            }, false);
        });

        // Handle file drop
        dropZone.addEventListener('drop', (e) => {
            let dt = e.dataTransfer;
            let files = dt.files;
            if (files.length > 0) {
                fileInput.files = files; // Assign dropped files to input
                updateFileInfo();
            }
        });

        // Handle file browse
        fileInput.addEventListener('change', updateFileInfo);

        function updateFileInfo() {
            if (fileInput.files.length > 0) {
                fileInfo.innerHTML = `Selected File: ${fileInput.files[0].name} (${(fileInput.files[0].size / 1024 / 1024).toFixed(2)} MB)`;
                urlInput.value = ''; // Clear URL if file is selected
                urlInput.disabled = true;
            } else {
                fileInfo.innerHTML = '';
                urlInput.disabled = false;
            }
        }
        
        // If user types in URL, clear file input
        urlInput.addEventListener('input', () => {
            if (urlInput.value.length > 0) {
                fileInput.value = '';
                fileInfo.innerHTML = '';
            }
        });
    </script>
</body>
</html>

