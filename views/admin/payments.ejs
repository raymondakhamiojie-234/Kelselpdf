<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>All Payments - Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
<link rel="icon" media="(prefers-color-scheme: light)" href="/acct/img/favicon-dark.png">
    <link rel="icon" media="(prefers-color-scheme: dark)" href="/acct/img/favicon-light.png">
</head>
<body class="dashboard-body">
    <nav class="sidebar">
        <img src="/acct/img/KelselPDF.png" alt="KelselPDF Logo" class="brand-logo" style="max-width: 150px; margin: 0 auto 2rem; display: block;">
        <ul>
            <li><a href="/admin">📊 Overview</a></li>
            <li><a href="/admin/users">👥 Users</a></li>
            <li><a href="/admin/payments" class="active">💰 Payments</a></li>
            <li><a href="/admin/subscriptions">📅 Subscriptions</a></li>
            <li><a href="/admin/questions">📝 Upload Questions</a></li>
            <li><a href="/admin/past_questions">📁 Past Questions</a></li>
            <li style="margin-top: 2rem;"><a href="/dashboard">← Back to App</a></li>
        </ul>
    </nav>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('../acct/partials/app_header', { page_title: 'Payments', page_desc: 'Revenue dashboard' }) %>

        <h2>Payment History Ledger</h2>
        <div class="glass-panel">
            <div class="table-responsive">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Reference</th>
                            <th>Plan</th>
                            <th>Amount (₦)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (payments.length === 0) { %>
                            <tr><td colspan="7" class="text-center">No transactions found.</td></tr>
                        <% } else { %>
                            <% payments.forEach(p => { %>
                            <tr>
                                <td><%= new Date(p.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) %></td>
                                <td><%= p.full_name %></td>
                                <td><%= p.email %></td>
                                <td><%= p.reference %></td>
                                <td><%= p.plan %></td>
                                <td><%= Number(p.amount).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                <td style="color: var(--success); text-transform: capitalize;"><%= p.status %></td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>





