<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Subscriptions - Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
</head>
<body class="dashboard-body">
    <nav class="sidebar">
        <img src="/acct/img/KelselPDF.png" alt="KelselPDF Logo" class="brand-logo" style="max-width: 150px; margin: 0 auto 2rem; display: block;">
        <ul>
            <li><a href="/admin">📊 Overview</a></li>
            <li><a href="/admin/payments">💰 Payments</a></li>
            <li><a href="/admin/subscriptions" class="active">📅 Subscriptions</a></li>
            <li><a href="/admin/questions">📝 Upload Questions</a></li>
            <li><a href="/admin/past_questions">📁 Past Questions</a></li>
            <li style="margin-top: 2rem;"><a href="/dashboard">← Back to App</a></li>
        </ul>
    </nav>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('../acct/partials/app_header', { page_title: 'Subscriptions', page_desc: 'User plans' }) %>

        <h2>Subscription Tracker</h2>
        <div class="glass-panel">
            <div class="table-responsive">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Plan</th>
                            <th>Expiry Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (subs.length === 0) { %>
                            <tr><td colspan="5" class="text-center">No users found.</td></tr>
                        <% } else { %>
                            <% 
                            const currentDate = new Date();
                            currentDate.setHours(0, 0, 0, 0); // start of today
                            
                            subs.forEach(s => { 
                                let status_color = 'var(--text-muted)';
                                let status_text = 'Unpaid';
                                
                                if (s.has_paid) {
                                    if (!s.expiry_date || new Date(s.expiry_date) <= currentDate) {
                                        status_color = 'var(--error)';
                                        status_text = 'Expired';
                                    } else {
                                        const expiryDate = new Date(s.expiry_date);
                                        const diff = expiryDate.getTime() - currentDate.getTime();
                                        const days = Math.round(diff / (1000 * 60 * 60 * 24));
                                        
                                        if (days <= 30) {
                                            status_color = 'orange';
                                            status_text = `Expiring in ${days} days`;
                                        } else {
                                            status_color = 'var(--success)';
                                            status_text = 'Active';
                                        }
                                    }
                                }
                            %>
                            <tr>
                                <td><%= s.full_name %></td>
                                <td><%= s.email %></td>
                                <td style="text-transform: capitalize;"><%= s.subscription_plan %></td>
                                <td><%= s.expiry_date ? new Date(s.expiry_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %></td>
                                <td style="color: <%= status_color %>; font-weight: bold;">
                                    <%= status_text %>
                                    <% if (status_text === 'Unpaid' || status_text === 'Expired') { %>
                                        <button onclick="copyPaymentLink()" style="margin-left: 10px; padding: 2px 8px; font-size: 0.8rem; border-radius: 4px; border: none; background: var(--primary); color: white; cursor: pointer;" title="Copy Payment Link">🔗 Copy Link</button>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
    <script>
        function copyPaymentLink() {
            const paymentUrl = window.location.origin + '/payment';
            navigator.clipboard.writeText(paymentUrl).then(() => {
                alert('Payment link copied to clipboard: ' + paymentUrl);
            }).catch(err => {
                alert('Failed to copy link. Please manually send: ' + paymentUrl);
            });
        }
    </script>
</body>
</html>

