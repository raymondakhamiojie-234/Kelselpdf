<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - KelselPDF</title>
    <link rel="stylesheet" href="/style.css?v=3">
    <script src="/theme.js"></script>
</head>
<body class="dashboard-body">
    <%- include('../acct/partials/sidebar', { active_page: 'admin' }) %>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('../acct/partials/app_header', { 
            page_title: 'Admin Portal', 
            page_desc: 'System Overview & Management',
            header_style: 'background: linear-gradient(135deg, #1E3A8A 0%, #059669 100%);',
            header_icon: '<svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>',
            search_placeholder: 'Search admin logs...'
        }) %>

        <h3 style="padding: 0 1.5rem; margin-bottom: 1rem; color: var(--ntxt-color);">Platform Stats</h3>

        <!-- Grid for Stats -->
        <div class="quick-access-grid">
            <div class="pastel-card bg-blue">
                <div class="icon-circle ic-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <h4><%= users_count %> Users</h4>
                <p>Total Registered</p>
            </div>

            <div class="pastel-card bg-green">
                <div class="icon-circle ic-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                </div>
                <h4>₦<%= Number(revenue).toLocaleString() %></h4>
                <p>Total Revenue</p>
            </div>

            <div class="pastel-card bg-orange">
                <div class="icon-circle ic-orange">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                </div>
                <h4><%= active_subs %> Active</h4>
                <p>Premium Subscribers</p>
            </div>
            
            <div class="pastel-card bg-purple">
                <div class="icon-circle ic-purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                </div>
                <h4><%= q_count %> / <%= pq_count %></h4>
                <p>Questions DB</p>
            </div>
        </div>

        <h3 style="padding: 0 1.5rem; margin-bottom: 1rem; color: var(--ntxt-color); margin-top: 1rem;">Management</h3>

        <!-- Grid for Admin Links -->
        <div class="quick-access-grid">
            <a href="/admin/payments" class="pastel-card bg-yellow">
                <div class="icon-circle ic-yellow">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
                </div>
                <h4>Payments</h4>
                <p>Transaction logs</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/admin/subscriptions" class="pastel-card bg-pink">
                <div class="icon-circle ic-pink">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                </div>
                <h4>Subscriptions</h4>
                <p>Manage access</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/admin/questions" class="pastel-card bg-blue">
                <div class="icon-circle ic-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </div>
                <h4>Questions</h4>
                <p>Upload CBT data</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>
            
            <a href="/admin/skills" class="pastel-card bg-orange">
                <div class="icon-circle ic-orange">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
                </div>
                <h4>Skills Academy</h4>
                <p>Manage courses</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>
        </div>
        
    </main>
</body>
</html>
