<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
</head>
<body>
    <nav class="sidebar">
        <img src="/acct/img/KelselPDF.png" alt="KelselPDF Logo" class="brand-logo" style="max-width: 150px; margin: 0 auto 2rem; display: block;">
        <ul>
            <li><a href="/admin" class="active">📊 Overview</a></li>
            <li><a href="/admin/payments">💰 Payments</a></li>
            <li><a href="/admin/subscriptions">📅 Subscriptions</a></li>
            <li><a href="/admin/questions">📝 Upload Questions</a></li>
            <li><a href="/admin/past_questions">📁 Past Questions</a></li>
            <li style="margin-top: 2rem;"><a href="/dashboard">← Back to App</a></li>
        </ul>
    </nav>

    <main class="main-content">
        <h2>Admin Overview</h2>
        
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <div class="glass-panel" style="flex: 1; min-width: 200px; text-align: center;">
                <h3>Total Users</h3>
                <h1 style="color: var(--cta-color); font-size: 2.5rem;"><%= users_count %></h1>
            </div>
            <div class="glass-panel" style="flex: 1; min-width: 200px; text-align: center;">
                <h3>Total Revenue</h3>
                <h1 style="color: var(--success); font-size: 2.5rem;">₦<%= Number(revenue).toLocaleString() %></h1>
            </div>
            <div class="glass-panel" style="flex: 1; min-width: 200px; text-align: center;">
                <h3>Active Subs</h3>
                <h1 style="color: var(--accent); font-size: 2.5rem;"><%= active_subs %></h1>
            </div>
            <div class="glass-panel" style="flex: 1; min-width: 200px; text-align: center;">
                <h3>Questions DB</h3>
                <h1 style="color: var(--sec-color); font-size: 2.5rem;"><%= q_count %></h1>
            </div>
            <div class="glass-panel" style="flex: 1; min-width: 200px; text-align: center;">
                <h3>Past Questions</h3>
                <h1 style="color: var(--ntxt-color); font-size: 2.5rem;"><%= pq_count %></h1>
            </div>
        </div>
    </main>
</body>
</html>
