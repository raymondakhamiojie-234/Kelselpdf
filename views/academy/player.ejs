<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= course.title %> - Player</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
            background: var(--bg);
        }
        .player-sidebar {
            width: 350px;
            background: var(--surface);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        .player-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .player-header h2 {
            font-size: 1.2rem;
            margin: 0 0 0.5rem 0;
        }
        .player-progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
            overflow: hidden;
            margin-top: 10px;
        }
        .player-progress-fill {
            height: 100%;
            background: var(--accent);
            width: <%= progress_percent %>%;
            transition: width 0.3s;
        }
        .module-list {
            flex: 1;
            overflow-y: auto;
        }
        .module-item {
            border-bottom: 1px solid var(--border-color);
        }
        .module-header {
            padding: 1rem 1.5rem;
            background: rgba(255,255,255,0.02);
            font-weight: 600;
            font-size: 0.95rem;
        }
        .lesson-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .lesson-item {
            padding: 0.8rem 1.5rem 0.8rem 2.5rem;
            display: flex;
            align-items: center;
            color: var(--ntxt-color);
            text-decoration: none;
            font-size: 0.9rem;
            border-left: 3px solid transparent;
        }
        .lesson-item:hover {
            background: rgba(255,255,255,0.05);
            color: var(--text-color);
        }
        .lesson-item.active {
            background: rgba(var(--accent-rgb), 0.1);
            border-left-color: var(--accent);
            color: var(--text-color);
            font-weight: 600;
        }
        .lesson-item.completed {
            opacity: 0.7;
        }
        .player-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }
        .video-container {
            width: 100%;
            background: #000;
            aspect-ratio: 16/9;
            max-height: 70vh;
        }
        .video-container iframe, .video-container video {
            width: 100%;
            height: 100%;
            border: none;
        }
        .lesson-content {
            padding: 2rem 3rem;
            max-width: 900px;
            margin: 0 auto;
            width: 100%;
        }
        .nav-buttons {
            display: flex;
            justify-content: space-between;
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-color);
        }
    </style>
</head>
<body>
    <div class="player-sidebar">
        <div class="player-header">
            <a href="/academy/course/<%= course.slug %>" style="color: var(--ntxt-color); text-decoration: none; font-size: 0.85rem; display: block; margin-bottom: 0.5rem;">&larr; Back to Course Overview</a>
            <h2><%= course.title %></h2>
            <div style="font-size: 0.8rem; color: var(--ntxt-color);"><%= Math.round(progress_percent) %>% Completed</div>
            <div class="player-progress-bar">
                <div class="player-progress-fill"></div>
            </div>
        </div>
        <div class="module-list">
            <% modules.forEach(function(mod, m_index) { %>
                <div class="module-item">
                    <div class="module-header">Section <%= m_index + 1 %>: <%= mod.title %></div>
                    <ul class="lesson-list">
                        <% mod.lessons.forEach(function(lesson) { 
                            let isActive = current_lesson && current_lesson.id === lesson.id;
                            let isCompleted = completed_lessons.includes(lesson.id);
                        %>
                            <a href="/academy/player/<%= course.slug %>?lesson=<%= lesson.id %>" class="lesson-item <%= isActive ? 'active' : '' %> <%= isCompleted ? 'completed' : '' %>">
                                <span style="margin-right: 10px; font-size: 1.1rem;">
                                    <% if(isCompleted) { %>✅<% } else if(lesson.type === 'video') { %>🎥<% } else if(lesson.type === 'quiz') { %>📝<% } else { %>📄<% } %>
                                </span>
                                <%= lesson.title %>
                            </a>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>
        </div>
    </div>

    <div class="player-main">
        <% if (!current_lesson) { %>
            <div class="lesson-content" style="text-align: center; margin-top: 10vh;">
                <h2>Welcome to <%= course.title %></h2>
                <p style="color: var(--ntxt-color);">Select a lesson from the sidebar to begin learning.</p>
                <% if(modules.length > 0 && modules[0].lessons.length > 0) { %>
                    <a href="/academy/player/<%= course.slug %>?lesson=<%= modules[0].lessons[0].id %>" class="btn btn-primary" style="margin-top: 1rem;">Start First Lesson</a>
                <% } %>
            </div>
        <% } else { %>
            
            <% if(current_lesson.type === 'video' && current_lesson.video_url) { %>
                <div class="video-container">
                    <!-- Assuming YouTube or Vimeo embed URL, adjust for direct MP4 if needed -->
                    <iframe src="<%= current_lesson.video_url %>" allowfullscreen></iframe>
                </div>
            <% } %>

            <div class="lesson-content">
                <h1 style="margin-bottom: 1rem;"><%= current_lesson.title %></h1>
                
                <div class="glass-panel" style="background: transparent; border: none; padding: 0;">
                    <%- current_lesson.content %>
                </div>

                <div class="nav-buttons">
                    <div>
                        <% if(prev_lesson_id) { %>
                            <a href="/academy/player/<%= course.slug %>?lesson=<%= prev_lesson_id %>" class="btn btn-outline">&larr; Previous</a>
                        <% } %>
                    </div>
                    
                    <div>
                        <% if(!completed_lessons.includes(current_lesson.id)) { %>
                            <form action="/academy/complete_lesson" method="POST" style="display: inline;">
                                <input type="hidden" name="course_slug" value="<%= course.slug %>">
                                <input type="hidden" name="lesson_id" value="<%= current_lesson.id %>">
                                <button type="submit" class="btn btn-success" style="background: var(--success); border: none;">Mark as Completed</button>
                            </form>
                        <% } else { %>
                            <span class="btn" style="background: rgba(255,255,255,0.1); cursor: default;">✅ Completed</span>
                        <% } %>
                        
                        <% if(next_lesson_id) { %>
                            <a href="/academy/player/<%= course.slug %>?lesson=<%= next_lesson_id %>" class="btn btn-primary" style="margin-left: 10px;">Next &rarr;</a>
                        <% } else if (progress_percent >= 90) { %>
                            <a href="/academy/certificate/<%= course.id %>" class="btn btn-ai" style="margin-left: 10px;">Claim Certificate 🏆</a>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>
