<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
</head>
<body>
    <div class="auth-wrapper">
        <div class="glass-panel auth-container">
            <div style="text-align: center; margin-bottom: 2rem;">
                <a href="/"><img src="/acct/img/KelselPDF.png" alt="KelselPDF Logo" style="max-width: 200px;"></a>
            </div>
            
            <h2>Welcome Back</h2>
            
            <% if (locals.error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
            <% } %>

            <form method="POST" action="/login">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" required placeholder="Enter your email">
                </div>
                
                <div class="form-group mb-2">
                    <label>Password</label>
                    <input type="password" name="password" required placeholder="Enter your password">
                </div>
                
                <button type="submit" class="btn btn-ai" style="width: 100%;">Sign In</button>
            </form>
            
            <p class="text-center mt-1">Don't have an account? <a href="/register">Register here</a></p>
        </div>
    </div>
</body>
</html>
