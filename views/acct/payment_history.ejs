<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Payment History - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
</head>
<body>
    <%- include('partials/sidebar', { active_page: 'billing' }) %>

    <main class="main-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h2>Payment History</h2>
            <a href="/payment" class="btn btn-ai">Upgrade / Renew Subscription</a>
        </div>

        <div class="glass-panel">
            <div class="table-responsive">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Reference</th>
                            <th>Plan</th>
                            <th>Amount Paid</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transactions.length === 0) { %>
                            <tr><td colspan="5" class="text-center">No payment history found.</td></tr>
                        <% } else { %>
                            <% transactions.forEach(t => { %>
                            <tr>
                                <td><%= new Date(t.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) %></td>
                                <td><%= t.reference %></td>
                                <td><%= t.plan %></td>
                                <td>₦<%= Number(t.amount).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                <td style="color: var(--success); text-transform: capitalize;"><%= t.status %></td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>
