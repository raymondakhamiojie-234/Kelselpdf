<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Portal - KelselPDF</title>
    <link rel="stylesheet" href="/style.css?v=3">
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
</head>
<body class="dashboard-body">
    <%- include('partials/sidebar', { active_page: 'dashboard' }) %>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('partials/app_header') %>

        <div style="display: flex; justify-content: space-between; padding: 0 1.5rem; margin-bottom: 1rem; align-items: center;">
            <h3 style="margin: 0; color: var(--ntxt-color);">Quick Access</h3>
            <a href="#" style="font-size: 0.8rem; color: var(--cta-color); font-weight: 500;">View All</a>
        </div>

        <!-- Grid -->
        <div class="quick-access-grid">
            <a href="/profile" class="pastel-card bg-purple">
                <div class="icon-circle ic-purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </div>
                <h4>Profile</h4>
                <p>View & edit profile</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/exam/setup" class="pastel-card bg-green">
                <div class="icon-circle ic-green">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <h4>Exams</h4>
                <p>Start a CBT exam</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/exam_materials" class="pastel-card bg-blue">
                <div class="icon-circle ic-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </div>
                <h4>Materials</h4>
                <p>Study resources</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/exam/analytics" class="pastel-card bg-yellow">
                <div class="icon-circle ic-yellow">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                </div>
                <h4>Analytics</h4>
                <p>View your grades</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/skills" class="pastel-card bg-orange">
                <div class="icon-circle ic-orange">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
                </div>
                <h4>Academy</h4>
                <p>Learn new skills</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/career" class="pastel-card bg-pink">
                <div class="icon-circle ic-pink">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                </div>
                <h4>Career Hub</h4>
                <p>Jobs & Mentors</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/community" class="pastel-card bg-purple">
                <div class="icon-circle ic-purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <h4>Community</h4>
                <p>Message & support</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>

            <a href="/certificates" class="pastel-card bg-blue">
                <div class="icon-circle ic-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                </div>
                <h4>Certificates</h4>
                <p>Credentials</p>
                <span class="card-arrow">&rsaquo;</span>
            </a>
        </div>
        
    </main>
</body>
</html>

