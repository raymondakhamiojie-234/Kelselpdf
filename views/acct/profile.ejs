                            <select name="level" required>
                                <option value="100" <%= user.level == 100 ? 'selected' : '' %>>100</option>
                                <option value="200" <%= user.level == 200 ? 'selected' : '' %>>200</option>
                                <option value="300" <%= user.level == 300 ? 'selected' : '' %>>300</option>
                                <option value="400" <%= user.level == 400 ? 'selected' : '' %>>400</option>
                                <option value="500" <%= user.level == 500 ? 'selected' : '' %>>500</option>
                            </select>
                        <% } else { %>
                            <select disabled style="opacity: 0.7; cursor: not-allowed; background: var(--cbg-color-2);">
                                <option value="<%= user.level %>" selected><%= user.level %></option>
                            </select>
                            <input type="hidden" name="level" value="<%= user.level %>">
                            <div style="font-size: 0.75rem; color: var(--ntxt-color); margin-top: 5px;">🔒 Level is locked. Renew subscription to change.</div>
                        <% } %>
                    </div>
                </div>

                <hr style="border: none; border-top: 1px solid var(--cbg-color-2); margin: 2rem 0;">
                
                <h3 class="mb-1">Subscription Details</h3>
                <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label>Current Plan</label>
                        <input type="text" value="<%= user.subscription_plan.charAt(0).toUpperCase() + user.subscription_plan.slice(1) %>" disabled style="color: var(--cta-color); font-weight: bold; opacity: 1;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Expiry Date</label>
                        <input type="text" value="<%= user.has_paid && user.expiry_date ? new Date(user.expiry_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Not Subscribed' %>" disabled style="opacity: 1;">
                    </div>
                </div>
                
                <div style="margin-bottom: 2rem;">
                    <a href="/payment" class="btn btn-outline" style="width: 100%; text-align: center; border-radius: 8px;">Renew Subscription Early</a>
                </div>

                <div class="flex-col mt-1">
                    <button type="submit" class="btn btn-ai" style="width: 100%;">Save Changes</button>
                </div>
