<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Dashboard - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
<link rel="icon" media="(prefers-color-scheme: light)" href="/acct/img/favicon-dark.png">
    <link rel="icon" media="(prefers-color-scheme: dark)" href="/acct/img/favicon-light.png">
</head>
<body class="dashboard-body">
    <%- include('partials/sidebar', { active_page: 'dashboard' }) %>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('partials/app_header', { page_title: 'Mock Exams', page_desc: 'Configure your practice test' }) %>

        <div class="glass-panel" style="max-width: 600px; margin: 0 auto;">
            <h1 class="text-center">Set your Exam</h1>
            <p class="text-center">Choose your parameters to begin.</p>
            
            <form id="examForm" method="GET" action="/exam/start">
                <div class="form-group">
                    <label>Course</label>
                    <select name="course" id="courseSelect" required>
                        <option value="">Select a course...</option>
                        <% if(courses && courses.length > 0) { %>
                            <% courses.forEach(function(c) { %>
                                <option value="<%= c.course_code %>"><%= c.course_code %></option>
                            <% }); %>
                        <% } else { %>
                            <!-- Fallback -->
                            <option value="GST101">GST101</option>
                            <option value="MTH101">MTH101</option>
                            <option value="PHY101">PHY101</option>
                        <% } %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Time Duration (Minutes)</label>
                    <input type="number" name="time" value="30" min="5" required>
                </div>
                <div class="form-group">
                    <label>Number of Questions</label>
                    <input type="number" name="questions" value="20" min="5" required>
                </div>
                
                <div class="flex-col mt-1">
                    <button type="submit" class="btn" style="width: 100%;">Start Exam</button>
                    <button type="button" onclick="startAIExam()" class="btn btn-ai" style="width: 100%;">🤖 Generate AI Practice</button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function startAIExam() {
            const course = document.getElementById('courseSelect').value;
            if (!course) {
                alert("Please select a course first.");
                return;
            }
            window.location.href = `/exam/ai/take/${encodeURIComponent(course)}`;
        }
    </script>
</body>
</html>





