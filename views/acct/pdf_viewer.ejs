<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>AI Tutor Viewer - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
</head>
<body class="dashboard-body">
    <%- include('partials/sidebar', { active_page: 'ai_tutor' }) %>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('partials/app_header', { page_title: 'Portal', page_desc: '' }) %>

        <h2>Study Material: AI Tutor</h2>
        
        <div class="split-screen">
            <div class="pdf-pane">
                <iframe src="<%= pdf_url %>" width="100%" height="100%" style="border:none;"></iframe>
            </div>
            
            <div class="chat-pane glass-panel">
                <div id="initSection" class="text-center" style="margin-top: 5rem;">
                    <h3>🤖 Chat with this Document</h3>
                    <p>Initialize the AI tutor to ask questions about this specific PDF.</p>
                    <button onclick="initAI()" id="initBtn" class="btn btn-ai mt-1">Initialize AI Tutor</button>
                </div>

                <div id="chatSection" style="display: none; height: 100%; flex-direction: column;">
                    <div class="chat-messages" id="chatBox">
                        <div class="message msg-ai">Hello! I have read the document. What would you like to know?</div>
                    </div>
                    <div class="chat-input">
                        <input type="text" id="userInput" placeholder="Ask a question..." onkeypress="if(event.key === 'Enter') sendMessage()">
                        <button onclick="sendMessage()" class="btn">Send</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        let sourceId = null;

        function initAI() {
            const btn = document.getElementById('initBtn');
            btn.innerText = "Initializing...";
            btn.disabled = true;

            fetch('/api/ai/pdf_chat', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    action: 'upload',
                    pdf_url: "<%= pdf_url %>"
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.sourceId) {
                    sourceId = data.sourceId;
                    document.getElementById('initSection').style.display = 'none';
                    document.getElementById('chatSection').style.display = 'flex';
                } else {
                    alert("Failed to initialize AI Tutor: " + (data.error || 'Unknown error'));
                    btn.innerText = "Initialize AI Tutor";
                    btn.disabled = false;
                }
            })
            .catch(err => {
                alert("Connection error.");
                btn.innerText = "Initialize AI Tutor";
                btn.disabled = false;
            });
        }

        function sendMessage() {
            const input = document.getElementById('userInput');
            const msg = input.value.trim();
            if (!msg || !sourceId) return;

            const chatBox = document.getElementById('chatBox');
            
            // Add user msg
            const userDiv = document.createElement('div');
            userDiv.className = 'message msg-user';
            userDiv.innerText = msg;
            chatBox.appendChild(userDiv);
            input.value = '';

            // Scroll to bottom
            chatBox.scrollTop = chatBox.scrollHeight;

            // Add typing indicator
            const aiDiv = document.createElement('div');
            aiDiv.className = 'message msg-ai';
            aiDiv.innerText = 'Thinking...';
            chatBox.appendChild(aiDiv);
            chatBox.scrollTop = chatBox.scrollHeight;

            fetch('/api/ai/pdf_chat', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    action: 'chat',
                    sourceId: sourceId,
                    message: msg
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.content) {
                    aiDiv.innerText = data.content;
                } else {
                    aiDiv.innerText = "Error: Could not get response.";
                }
                chatBox.scrollTop = chatBox.scrollHeight;
            })
            .catch(err => {
                aiDiv.innerText = "Connection error.";
            });
        }
    </script>
</body>
</html>

