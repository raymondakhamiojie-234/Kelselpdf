<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Records & Analytics - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/theme.js"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW setup failed: ', err));
            });
        }
    </script>
<link rel="icon" type="image/png" href="/acct/img/favicon.png">
</head>
<body class="dashboard-body">
    <%- include('partials/sidebar', { active_page: 'exam_analytics' }) %>

    <main class="main-content">
        <!-- Curved Header -->
        <%- include('partials/app_header', { page_title: 'Analytics', page_desc: 'Track your performance' }) %>

        <!-- AI Insights Card -->
        <div id="aiInsightCard" class="glass-panel mb-2" style="border-left: 4px solid var(--accent); display: none;">
            <h3>🤖 AI Tutor Insights</h3>
            <p id="aiInsightText">Analyzing your performance...</p>
        </div>

        <div class="glass-panel mb-2">
            <h2>Performance Overview</h2>
            <div style="height: 300px; width: 100%;">
                <canvas id="scoreChart"></canvas>
            </div>
        </div>

        <div class="glass-panel mb-2">
            <h2>Recent Attempts</h2>
            <div class="table-responsive">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Course</th>
                            <th>Score</th>
                            <th>Total</th>
                            <th>Percentage</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (attempts.length === 0) { %>
                            <tr><td colspan="5">No attempts recorded yet.</td></tr>
                        <% } else { %>
                            <% attempts.forEach(a => { %>
                            <tr>
                                <td><%= new Date(a.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) %></td>
                                <td><%= a.course_code %></td>
                                <td><%= a.score %></td>
                                <td><%= a.total_questions %></td>
                                <td><%= Math.round((a.score / a.total_questions) * 100 * 10) / 10 %>%</td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="glass-panel">
            <h2>Study Materials</h2>
            <ul style="list-style: none;">
                <% if (past_questions.length === 0) { %>
                    <li style="color: var(--text-muted);">No materials available at the moment.</li>
                    <!-- Mock material for demo -->
                    <li style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <strong>GST101</strong> - 2023 Past Question
                        </div>
                        <div style="display: flex; gap: 10px;">
                            <a href="#" target="_blank" class="btn" style="padding: 5px 10px; font-size: 0.85rem;">Download</a>
                            <a href="/exam/ai/pdf?url=https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf" class="btn btn-ai" style="padding: 5px 10px; font-size: 0.85rem;">🤖 Chat with PDF</a>
                        </div>
                    </li>
                <% } else { %>
                    <% past_questions.forEach(pq => { %>
                    <li style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <strong><%= pq.course_code %></strong> - <%= pq.year %> (<%= pq.type %>)
                        </div>
                        <div style="display: flex; gap: 10px;">
                            <a href="<%= (pq.file_link.startsWith('http') || pq.file_link.startsWith('data:')) ? pq.file_link : '/' + pq.file_link %>" target="_blank" class="btn" style="padding: 5px 10px; font-size: 0.85rem;">Download File</a>
                            <a href="/exam/ai/pdf?url=<%= encodeURIComponent(pq.file_link) %>" class="btn btn-ai" style="padding: 5px 10px; font-size: 0.85rem;">🤖 Chat with PDF</a>
                        </div>
                    </li>
                    <% }); %>
                <% } %>
            </ul>
        </div>
    </main>

    <script>
        // Chart.js Setup
        const ctx = document.getElementById('scoreChart').getContext('2d');
        const labels = <%- labels %>;
        const data = <%- data %>;

        if (labels.length > 0) {
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Average Score (%)',
                        data: data,
                        backgroundColor: 'rgba(59, 130, 246, 0.5)',
                        borderColor: 'rgba(59, 130, 246, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, max: 100, grid: { color: 'rgba(255,255,255,0.1)' }, ticks: { color: '#94a3b8' } },
                        x: { grid: { color: 'rgba(255,255,255,0.1)' }, ticks: { color: '#94a3b8' } }
                    },
                    plugins: { legend: { labels: { color: '#f8fafc' } } }
                }
            });
        }

        // Fetch AI Insights (Optional, to be implemented later in AI endpoints)
        document.addEventListener('DOMContentLoaded', () => {
            if (labels.length > 0) {
                // For now, mock AI insight or uncomment when /api/ai/insights is ready
                // document.getElementById('aiInsightCard').style.display = 'block';
            }
        });
    </script>
</body>
</html>




