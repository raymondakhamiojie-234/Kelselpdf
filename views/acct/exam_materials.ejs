<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Exam Materials - KelselPDF</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/theme.js"></script>
</head>
<body>
    <%- include('partials/sidebar', { active_page: 'exam_materials' }) %>

    <main class="main-content">
        <h2>Exam Materials</h2>
        <p style="color: var(--ntxt-color); margin-bottom: 2rem;">Download past questions and materials curated for your department and level.</p>
        
        <div class="glass-panel" style="max-width: 900px;">
            <% if (materials.length === 0) { %>
                <div style="text-align: center; padding: 2rem;">
                    <h3 style="color: var(--ntxt-color);">No materials available yet.</h3>
                    <p style="color: var(--ntxt-color);">Check back later or contact your admin.</p>
                </div>
            <% } else { %>
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--cbg-color-2); text-align: left;">
                            <th style="padding: 1rem;">Course Code</th>
                            <th style="padding: 1rem;">Year</th>
                            <th style="padding: 1rem;">Exam Type</th>
                            <th style="padding: 1rem; text-align: center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% materials.forEach(mat => { %>
                            <tr style="border-bottom: 1px solid var(--cbg-color-2);">
                                <td style="padding: 1rem; font-weight: bold; color: var(--cta-color);"><%= mat.course_code %></td>
                                <td style="padding: 1rem;"><%= mat.year %></td>
                                <td style="padding: 1rem;"><%= mat.type %></td>
                                <td style="padding: 1rem; text-align: center;">
                                    <% 
                                        const filePath = mat.file_link.startsWith('http') ? mat.file_link : '/' + mat.file_link; 
                                    %>
                                    <a href="<%= filePath %>" target="_blank" class="btn btn-ai" style="padding: 5px 15px; font-size: 0.9rem; border-radius: 20px;">Download</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </main>
</body>
</html>
